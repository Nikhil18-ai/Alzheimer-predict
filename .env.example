# Supabase (optional — only needed if you use the Edge Function path)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API key (used by the Vite proxy in dev, and server/proxy.ts in prod)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase Edge Function environment secrets (alternative backend path)
# OPENAI_API_KEY=sk-...
# AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1/chat/completions
# AI_GATEWAY_KEY=your-gateway-key
